{
  "run_name": "global_lightgbm_bdg1_250",
  "data_dir": "Building Data Genome Project 1",
  "lookback_hours": 168,
  "forecast_horizon": 24,
  "selection": {
    "max_meters": 250,
    "meters_per_primary_use": 50,
    "min_completeness": 0.98,
    "site_balanced": true,
    "max_meters_per_site": 50,
    "primary_uses": [
      "Office",
      "Primary/Secondary Classroom",
      "College Classroom",
      "College Laboratory",
      "Dormitory"
    ]
  },
  "weather": {
    "enabled": true,
    "features": [
      "airTemperature",
      "dewTemperature",
      "precipDepth1HR",
      "seaLvlPressure",
      "windDirection",
      "windSpeed"
    ],
    "use_origin_weather": true,
    "use_target_weather": true
  },
  "splits": {
    "train": {
      "target_start": "2015-01-01 00:00:00",
      "target_end": "2015-06-30 23:00:00"
    },
    "val": {
      "target_start": "2015-07-01 00:00:00",
      "target_end": "2015-09-30 23:00:00"
    },
    "test": {
      "target_start": "2015-10-01 00:00:00",
      "target_end": "2015-12-31 23:00:00"
    }
  },
  "lightgbm": {
    "n_estimators": 350,
    "learning_rate": 0.05,
    "num_leaves": 63,
    "subsample": 0.9,
    "colsample_bytree": 0.9,
    "random_state": 42,
    "n_jobs": -1,
    "verbosity": -1,
    "early_stopping_rounds": 30
  }
}
