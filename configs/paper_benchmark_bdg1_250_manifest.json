{
  "run_name": "paper_benchmark_bdg1_250",
  "description": "250-building BDG1 benchmark lineup for cross-dataset BaEF validation.",
  "experiments": [
    {
      "id": "historical_average_bdg1_250",
      "paper_role": "baseline",
      "metrics_file": "outputs/results/global_lightgbm_bdg1_250_metrics.csv",
      "model": "HistoricalAverage",
      "split": "test",
      "note": "Historical Average is emitted by the LightGBM benchmark pipeline."
    },
    {
      "id": "global_lightgbm_building_aware_bdg1_250",
      "paper_role": "baseline",
      "metrics_file": "outputs/results/global_lightgbm_bdg1_250_metrics.csv",
      "model": "GlobalLightGBM-building-aware",
      "split": "test",
      "note": "Strong tree baseline with building metadata and weather."
    },
    {
      "id": "global_lstm_bdg1_250",
      "paper_role": "baseline",
      "metrics_file": "outputs/results/global_lstm_bdg1_250_metrics.csv",
      "model": "GlobalLSTM-load-only",
      "split": "test",
      "note": "Sequence-model baseline on the aligned 250-building BDG1 protocol."
    },
    {
      "id": "global_patchtst_bdg1_250",
      "paper_role": "baseline",
      "metrics_file": "outputs/results/global_patchtst_bdg1_250_metrics.csv",
      "model": "GlobalPatchTST-load-only",
      "split": "test",
      "note": "PatchTST baseline on the aligned 250-building BDG1 protocol."
    },
    {
      "id": "global_itransformer_bdg1_250",
      "paper_role": "baseline",
      "metrics_file": "outputs/results/global_itransformer_bdg1_250_metrics.csv",
      "model": "GlobalITransformer-load-only",
      "split": "test",
      "note": "Vanilla iTransformer baseline on BDG1."
    },
    {
      "id": "building_aware_itransformer_bdg1_250_noweather",
      "paper_role": "building-aware",
      "metrics_file": "outputs/results/building_aware_itransformer_bdg1_250_noweather_metrics.csv",
      "model": "GlobalITransformer-building-aware",
      "split": "test",
      "note": "Building-aware iTransformer with static architecture metadata and no weather branch on BDG1."
    }
  ]
}
