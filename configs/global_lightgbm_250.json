{
  "run_name": "global_lightgbm_250",
  "data_dir": "Building Data Genome Project 2",
  "lookback_hours": 168,
  "forecast_horizon": 24,
  "selection": {
    "max_meters": 250,
    "meters_per_primary_use": 50,
    "min_completeness": 0.98,
    "site_balanced": true,
    "max_meters_per_site": 30,
    "primary_uses": [
      "Education",
      "Office",
      "Lodging/residential",
      "Entertainment/public assembly",
      "Public services"
    ]
  },
  "weather": {
    "enabled": true,
    "features": [
      "airTemperature",
      "dewTemperature",
      "precipDepth1HR",
      "seaLvlPressure",
      "windDirection",
      "windSpeed"
    ],
    "use_origin_weather": true,
    "use_target_weather": true
  },
  "splits": {
    "train": {
      "target_start": "2016-01-01 00:00:00",
      "target_end": "2016-12-31 23:00:00"
    },
    "val": {
      "target_start": "2017-01-01 00:00:00",
      "target_end": "2017-06-30 23:00:00"
    },
    "test": {
      "target_start": "2017-07-01 00:00:00",
      "target_end": "2017-12-31 23:00:00"
    }
  },
  "lightgbm": {
    "n_estimators": 350,
    "learning_rate": 0.05,
    "num_leaves": 63,
    "subsample": 0.9,
    "colsample_bytree": 0.9,
    "random_state": 42,
    "n_jobs": -1,
    "verbosity": -1,
    "early_stopping_rounds": 30
  }
}
